# SKALE MPP Web Demo Environment Configuration

# Get your WalletConnect Project ID from https://cloud.walletconnect.com
# This is required for RainbowKit wallet connections
VITE_WALLET_CONNECT_PROJECT_ID=your_project_id_here

# Server URL - where the MPP server is running
VITE_SERVER_URL=http://localhost:3000

# Optional: Token addresses (defaults are set in the app)
# VITE_USDC_ADDRESS=0xc4083B1E81ceb461Ccef3FDa8A9F24F0d764B6D8
# VITE_EUSDC_ADDRESS=0x36A9040DAC18D008a11Dc600d5EB1Cc89bb45200
